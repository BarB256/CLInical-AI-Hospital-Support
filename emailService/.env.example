# Database
DATABASE_URL=postgresql://user:password@localhost:5432/clinical

# API Keys (comma-separated)
API_KEYS=your-api-key-here

# SMTP — MailHog defaults (local demo, no auth required)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@clinical.local
SMTP_USE_TLS=false

# Gmail example (uncomment and fill in for real delivery)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_USE_TLS=true
